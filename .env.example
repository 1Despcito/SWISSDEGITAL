# ─────────────────────────────────────────────────────────────
# SwissDigiAI — environment variables
# Copy to `.env.local` for local dev. Never commit real keys.
# In Vercel, set these for Production, Preview AND Development.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for canonical/hreflang/sitemap/OG)
NEXT_PUBLIC_SITE_URL=https://swissdigiai.ch

# ── AI chatbot (server only) ──────────────────────────────────
# Anthropic Claude (preferred). Alternatively set OPENAI_API_KEY.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Lead backup store (server only) ───────────────────────────
# Neon (or any) Postgres connection string. Leads are persisted here so none is
# ever lost, even if email delivery fails. Table is auto-created on first write.
DATABASE_URL=

# ── Admin dashboard (/dashboard) ──────────────────────────────
# Password to sign in to the leads dashboard.
DASHBOARD_PASSWORD=
# Secret used to sign the session cookie (any long random string).
SESSION_SECRET=

# ── Transactional email (server only) ─────────────────────────
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@swissdigiai.ch
# Verified sender on your Resend domain
CONTACT_FROM_EMAIL=hello@swissdigiai.ch

# ── Booking ───────────────────────────────────────────────────
# Cal.com (preferred) e.g. "swissdigiai/discovery" OR full Calendly URL
NEXT_PUBLIC_CAL_LINK=swissdigiai/discovery

# ── Analytics ─────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
# Optional privacy-friendly analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Rate limiting for /api/chat (optional, server only) ───────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── CRM (optional, server only) ───────────────────────────────
HUBSPOT_TOKEN=

# ── Spam protection (optional) ────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
